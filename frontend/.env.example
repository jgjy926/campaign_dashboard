# URL of the deployed Cloudflare Worker (no trailing slash), e.g.
#   https://cashback-optimizer.<your-subdomain>.workers.dev
VITE_WORKER_URL=

# Shared secret sent as the X-App-Auth header. Must match the Worker's APP_API_KEY.
# Generate one with:  node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
VITE_APP_API_KEY=

# Optional: base path for GitHub Pages deploys, e.g. /campaign-dashboard/
# VITE_BASE=/
